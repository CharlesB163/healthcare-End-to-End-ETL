    "from Extract import extract\n",
    "from Transform import transform\n",
    "from Load import load\n",
    "\n",
    "def run_pipeline():\n",
    "    print(\"Starting ETL pipeline...\")\n",
    "\n",
    "    df = extract()\n",
    "    df = transform(df)\n",
    "    load(df)\n",
    "\n",
    "    print(\"ETL pipeline completed!\")\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    run_pipeline()"
